<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
    ExtensionBundleId="com.rmc.mockuptool"
    ExtensionBundleVersion="0.1.0.0"
    ExtensionBundleName="RMC MockupTool">

    <ExtensionList>
        <Extension Id="com.rmc.mockuptool.main"/>
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="ILST" Version="[0.0,99.9]"/>
        </HostList>
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.rmc.mockuptool.main">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--disable-web-security</Parameter>
                    </CEFCommandLine>
                </Resources>

                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>

                <UI>
                    <Type>Panel</Type>
                    <Menu>RMC MockupTool</Menu>
                    <Geometry>
                        <Size>
                            <Width>620</Width>
                            <Height>760</Height>
                        </Size>
                        <MinSize>
                            <Width>420</Width>
                            <Height>560</Height>
                        </MinSize>
                        <MaxSize>
                            <Width>1100</Width>
                            <Height>1200</Height>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
